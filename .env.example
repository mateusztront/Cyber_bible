# Instagram credentials
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ElevenLabs API (for text-to-speech)
ELEVENLABS_API_KEY=

# Optional: Voice ID for ElevenLabs
ELEVENLABS_VOICE_ID=3Ehk82QdxNa83Vm0xjf7

# =============================================================================
# MIDJOURNEY API (Discord-based, unofficial)
# WARNING: Using this violates Midjourney ToS. Use at your own risk.
#
# HOW TO GET THESE VALUES:
# ========================
# 1. Open Discord in your browser (discord.com) - NOT the desktop app
# 2. Go to a server/channel where you have Midjourney bot
# 3. Open DevTools: Press F12 (or Ctrl+Shift+I / Cmd+Option+I)
# 4. Go to the "Network" tab
# 5. In the Discord chat, type /imagine and send any prompt
# 6. In the Network tab, look for a request to "interactions"
# 7. Click on it and go to "Payload" or "Request" tab
# 8. You'll see a JSON like this - extract the values:
#
#    {
#      "type": 2,
#      "application_id": "936929561302675456",  <-- MJ_APPLICATION_ID
#      "guild_id": "123456789012345678",        <-- MJ_GUILD_ID
#      "channel_id": "987654321098765432",      <-- MJ_CHANNEL_ID
#      "data": {
#        "version": "1234567890123456789",      <-- MJ_VERSION
#        "id": "9876543210987654321",           <-- MJ_ID
#        ...
#      }
#    }
#
# 9. For DISCORD_AUTH_TOKEN:
#    - In DevTools, go to "Application" tab (or "Storage")
#    - Expand "Local Storage" > "https://discord.com"
#    - Find "token" and copy its value (remove quotes)
#    OR
#    - In Network tab, look at request headers for "Authorization"
#
# =============================================================================
DISCORD_AUTH_TOKEN=
MJ_APPLICATION_ID=
MJ_GUILD_ID=
MJ_CHANNEL_ID=
MJ_VERSION=
MJ_ID=

# Rate limiting (seconds between requests) - helps avoid detection
MJ_DELAY_MIN=5
MJ_DELAY_MAX=15

